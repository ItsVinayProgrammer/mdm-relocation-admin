rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return signedIn() && request.auth.token.email == "itsvinayprogrammer@gmail.com";
    }

    function isAuthorizedUser() {
      return signedIn()
        && request.auth.token.email != null
        && exists(/databases/$(database)/documents/authorized_users/$(request.auth.token.email));
    }

    match /authorized_users/{userEmail} {
      allow get: if isSuperAdmin() || (
        signedIn()
        && request.auth.token.email != null
        && request.auth.token.email == userEmail
      );

      allow list: if isSuperAdmin();
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && userEmail != "itsvinayprogrammer@gmail.com";
    }

    match /bookings/{bookingId} {
      allow create: if true;
      allow get, list, delete: if isSuperAdmin() || isAuthorizedUser();
      allow update: if isSuperAdmin();
    }

    match /submissions/{submissionId} {
      allow create: if true;
      allow get, list, delete: if isSuperAdmin() || isAuthorizedUser();
      allow update: if isSuperAdmin();
    }

    match /admin_activity_logs/{logId} {
      allow get, list: if isSuperAdmin() || isAuthorizedUser();
      allow create: if isSuperAdmin() || (
        isAuthorizedUser()
        && request.resource.data.email == request.auth.token.email
      );
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}