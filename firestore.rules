rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function normalizedAuthEmail() {
      return signedIn() && request.auth.token.email != null
        ? request.auth.token.email.lower()
        : null;
    }

    function isSuperAdmin() {
      return normalizedAuthEmail() == "itsvinayprogrammer@gmail.com";
    }

    function isAuthorizedUser() {
      return normalizedAuthEmail() != null
        && exists(/databases/$(database)/documents/authorized_users/$(normalizedAuthEmail()));
    }

    match /authorized_users/{userEmail} {
      allow get: if isSuperAdmin() || (
        normalizedAuthEmail() != null
        && normalizedAuthEmail() == userEmail.lower()
      );

      allow list: if isSuperAdmin();
      allow create, update: if isSuperAdmin();
      allow delete: if isSuperAdmin() && userEmail.lower() != "itsvinayprogrammer@gmail.com";
    }

    match /bookings/{bookingId} {
      allow create: if true;
      allow get, list, delete: if isSuperAdmin() || isAuthorizedUser();
      allow update: if isSuperAdmin();
    }

    match /submissions/{submissionId} {
      allow create: if true;
      allow get, list, delete: if isSuperAdmin() || isAuthorizedUser();
      allow update: if isSuperAdmin();
    }

    match /admin_activity_logs/{logId} {
      allow get, list: if isSuperAdmin();
      allow create: if normalizedAuthEmail() != null
        && request.resource.data.email is string
        && request.resource.data.email.lower() == normalizedAuthEmail();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}